// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  USER
}

enum CategoryType {
  HARDWARE
  SOFTWARE
}

enum AssetStatus {
  AVAILABLE
  DEPLOYED
  UNDER_REPAIR
  ARCHIVED
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  ASSIGNED
  RETURNED
  STATUS_CHANGED
}

// ─────────────────────────────────────────────
// Department
// ─────────────────────────────────────────────

model Department {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(150)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@map("departments")
}

// ─────────────────────────────────────────────
// User  (also used as NextAuth user)
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?   @db.VarChar(150)
  email         String    @unique @db.VarChar(255)
  emailVerified DateTime?
  image         String?   @db.Text
  password      String?   @db.VarChar(255) // hashed; null when OAuth-only
  role          UserRole  @default(USER)
  isActive      Boolean   @default(true)
  location      String?   @db.VarChar(100)
  departmentId  String?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  department Department? @relation(fields: [departmentId], references: [id])

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Business relations
  assignments         Assignment[] @relation("AssignmentUser")
  assignmentsCreated  Assignment[] @relation("AssignmentCreatedBy")
  auditLogs           AuditLog[]

  @@map("users")
}

// ─────────────────────────────────────────────
// Category
// ─────────────────────────────────────────────

model Category {
  id          String       @id @default(cuid())
  name        String       @unique @db.VarChar(100)
  type        CategoryType
  description String?      @db.Text
  createdAt   DateTime     @default(now())

  assets   Asset[]
  licenses License[]

  @@map("categories")
}

// ─────────────────────────────────────────────
// Asset  (Hardware)
// ─────────────────────────────────────────────

model Asset {
  id            String      @id @default(cuid())
  assetTag      String      @unique @db.VarChar(50)  // used for QR code
  serialNumber  String?     @unique @db.VarChar(100)
  name          String      @db.VarChar(200)
  model         String?     @db.VarChar(150)
  manufacturer  String?     @db.VarChar(150)
  categoryId    String
  status        AssetStatus @default(AVAILABLE)
  purchaseDate  DateTime?
  warrantyExpiry DateTime?
  purchaseCost  Decimal?    @db.Decimal(12, 2)
  location      String?     @db.VarChar(200)
  notes         String?     @db.Text

  // Soft delete
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category    Category     @relation(fields: [categoryId], references: [id])
  assignments Assignment[] @relation("AssetAssignments")

  @@index([status])
  @@index([categoryId])
  @@index([warrantyExpiry])
  @@index([deletedAt])
  @@map("assets")
}

// ─────────────────────────────────────────────
// License  (Software)
// ─────────────────────────────────────────────

model License {
  id             String   @id @default(cuid())
  name           String   @db.VarChar(200)
  licenseKey     String?  @db.VarChar(500)
  vendor         String?  @db.VarChar(150)
  categoryId     String
  totalSeats     Int      @default(1)
  availableSeats Int      @default(1)
  expirationDate DateTime?
  isSubscription Boolean  @default(false)
  purchaseCost   Decimal? @db.Decimal(12, 2)
  notes          String?  @db.Text

  // Soft delete
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category    Category     @relation(fields: [categoryId], references: [id])
  assignments Assignment[] @relation("LicenseAssignments")

  @@index([categoryId])
  @@index([expirationDate])
  @@index([deletedAt])
  @@map("licenses")
}

// ─────────────────────────────────────────────
// Assignment  (Zimmet)
// ─────────────────────────────────────────────
// Either assetId OR licenseId is set — never both.
// Enforced at application layer; checked in API.

model Assignment {
  id         String    @id @default(cuid())
  assetId    String?
  licenseId  String?
  userId     String
  assignedBy String
  assignedAt DateTime  @default(now())
  returnedAt DateTime?
  notes      String?   @db.Text

  asset    Asset?   @relation("AssetAssignments", fields: [assetId], references: [id])
  license  License? @relation("LicenseAssignments", fields: [licenseId], references: [id])
  user     User     @relation("AssignmentUser", fields: [userId], references: [id])
  createdBy User    @relation("AssignmentCreatedBy", fields: [assignedBy], references: [id])

  @@index([userId])
  @@index([assetId])
  @@index([licenseId])
  @@index([returnedAt])
  @@map("assignments")
}

// ─────────────────────────────────────────────
// AuditLog
// ─────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  entityType String      @db.VarChar(50)  // "Asset" | "License" | "Assignment" | "User"
  entityId   String      @db.VarChar(50)
  action     AuditAction
  changedBy  String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?     @db.VarChar(45)
  userAgent  String?     @db.Text
  createdAt  DateTime    @default(now())

  // entityType + entityId form a polymorphic reference (no FK constraint — queried in app logic)
  user User @relation(fields: [changedBy], references: [id])

  @@index([entityType, entityId])
  @@index([changedBy])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// NextAuth.js Adapter Tables
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// System Settings  (key-value store)
// ─────────────────────────────────────────────

model SystemSetting {
  key       String   @id @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
